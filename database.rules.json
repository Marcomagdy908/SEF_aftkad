{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "users": {
      "$userId": {
        ".validate": "newData.hasChildren(['name', 'role'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "role": {
          ".validate": "newData.isString() && (newData.val() == 'خادم' || newData.val() == 'مخدوم')"
        },
        "phone": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "department": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "memberId": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "classYear": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "college": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "section": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "servant1": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "servant2": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "originalChurch": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "serviceType": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "address": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "hobbies": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "deptYear": {
          ".validate": "!newData.exists() || newData.isString()"
        }
      }
    },

    "events": {
      "$eventId": {
        ".validate": "newData.hasChildren(['name', 'date'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "date": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "description": {
          ".validate": "!newData.exists() || newData.isString()"
        }
      }
    },

    "attendance": {
      "$eventId": {
        "$userId": {
          ".validate": "newData.isString() && (newData.val() == 'Present' || newData.val() == 'Absent')"
        }
      }
    }
  }
}
